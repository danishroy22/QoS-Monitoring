# Copy to backend/.env and adjust as needed.

# Database connection.
# Default (out-of-the-box, no server required): local SQLite file.
QOS_DATABASE_URL=sqlite:///./qos_monitoring.db

# PostgreSQL example (documented dissertation target). Install psycopg first:
#   pip install "psycopg[binary]"
# QOS_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/qos_monitoring

# API metadata
QOS_APP_NAME=ai-broadband-qos-backend
QOS_API_PREFIX=/api

# CORS: comma-separated origins allowed to call the API (React dev server).
QOS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Seed the default simulator nodes on startup (true/false).
QOS_SEED_NODES=true

# Phase 6 — Generative AI (optional).
# Leave QOS_OPENAI_API_KEY empty to use the offline telecom fallback generator.
# QOS_OPENAI_API_KEY=sk-...
# QOS_OPENAI_BASE_URL=https://api.openai.com/v1
# QOS_OPENAI_MODEL=gpt-4o-mini
# QOS_AI_FORCE_FALLBACK=false
# QOS_AI_TIMEOUT_SECONDS=30
